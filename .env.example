# ─── Binance Futures Testnet ───────────────────────────────────────────────────
# Get keys at: https://testnet.binancefuture.com
# 1. Open the link → Register / Log in
# 2. Click "Generate HMAC_SHA256 Key" in the API section
# 3. Copy Key + Secret below

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
BINANCE_TESTNET=true        # Set to false when going live (DANGEROUS)

# ─── Bot Settings ──────────────────────────────────────────────────────────────
INITIAL_BALANCE_USDT=100    # Starting capital
MAX_RISK_PER_TRADE=0.02     # 2% max account risk per trade
DAILY_DRAWDOWN_LIMIT=0.15   # Halt bot if daily loss > 15%
LEVERAGE=10                 # Futures leverage (10x = conservative for scalping)

# ─── Pairs to trade (comma-separated) ─────────────────────────────────────────
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
